APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
APP_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Optional API-key auth. CSV of keys; clients must send X-API-Key.
# Empty (default) means open access — keep it empty for single-user / local dev.
APP_API_KEYS=

# Encryption-at-rest for provider secrets stored in app_settings.
# Generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to disable encryption (plaintext storage; warn-logged in production).
APP_ENCRYPTION_KEY=

# Observability + abuse-protection (Epic 4).
# /metrics exposes Prometheus text format when enabled.
METRICS_ENABLED=true
# Per-client (API key or IP) request limit per 60s window. 0 = disabled.
RATE_LIMIT_PER_MINUTE=0

# Artifact storage backend. "local" writes under ARTIFACT_ROOT (default).
# "s3" pushes to S3 / MinIO / R2 — requires the S3_* vars below + boto3 installed.
STORAGE_BACKEND=local
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PREFIX=artifacts/

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/voiceforge
REDIS_URL=redis://redis:6379/0

ARTIFACT_ROOT=/data/artifacts
CACHE_ROOT=/data/cache
LOG_LEVEL=INFO
LOG_FILE_PATH=/data/logs/voiceforge.log
EVENT_STREAM_POLL_SECONDS=2
MONITOR_DOCKER_SOCKET_PATH=/var/run/docker.sock
MONITOR_CONTAINER_LOGS_ENABLED=true
PREVIEW_SAMPLE_TEXT_VI=Xin chào, đây là bản nghe thử giọng nói.
PREVIEW_SAMPLE_TEXT_EN=Hello, this is a short preview of the selected voice.

VOICE_CATALOG_REFRESH_ON_START=true
VOICE_CATALOG_REFRESH_TIMEOUT_SECONDS=8

JOB_MAX_RUNTIME_SECONDS=900
JOB_REAPER_INTERVAL_SECONDS=60
JOB_REAPER_ENABLED=true

BULK_IMPORT_MAX_ROWS=5000
BULK_IMPORT_MAX_BYTES=5242880

PREVIEW_MAX_CHARS=500

# Per-provider concurrency limit. Cloud providers default to 4 (network-bound,
# many providers can serve parallel TTS calls); self-hosted ones default to 1
# (CPU/GPU-bound, single backend). Override per-provider via the JSON dict.
PROVIDER_CONCURRENCY_CLOUD=4
PROVIDER_CONCURRENCY_SELF_HOSTED=1
PROVIDER_CONCURRENCY={}

# Subtitle generation (T1.3) — fallback char/sec rate when a row's
# duration_seconds is null. 15 cps (~ Vietnamese/English speech) is fine for
# personal-use; tune higher for fast narration, lower for slow.
SUBTITLE_CHARS_PER_SECOND=15

VOICEVOX_BASE_URL=http://voicevox:50021
VOICEVOX_TIMEOUT_SECONDS=30

PIPER_BASE_URL=
PIPER_TIMEOUT_SECONDS=60
PIPER_VOICE_IDS=vi_VN-vais1000-medium,en_US-lessac-medium,en_GB-alan-medium
PIPER_DOWNLOAD_ON_START=true

KOKORO_BASE_URL=
KOKORO_TIMEOUT_SECONDS=30

VIENEU_TTS_BASE_URL=
VIENEU_TTS_TIMEOUT_SECONDS=240

OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts

ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

GOOGLE_TTS_ACCESS_TOKEN=
GOOGLE_TTS_PROJECT_ID=

AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
