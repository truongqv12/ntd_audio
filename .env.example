APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
APP_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/voiceforge
REDIS_URL=redis://redis:6379/0

ARTIFACT_ROOT=/data/artifacts
CACHE_ROOT=/data/cache
LOG_LEVEL=INFO
LOG_FILE_PATH=/data/logs/voiceforge.log
EVENT_STREAM_POLL_SECONDS=2
MONITOR_DOCKER_SOCKET_PATH=/var/run/docker.sock
MONITOR_CONTAINER_LOGS_ENABLED=true
PREVIEW_SAMPLE_TEXT_VI=Xin chào, đây là bản nghe thử giọng nói.
PREVIEW_SAMPLE_TEXT_EN=Hello, this is a short preview of the selected voice.

VOICE_CATALOG_REFRESH_ON_START=true
VOICE_CATALOG_REFRESH_TIMEOUT_SECONDS=8

JOB_MAX_RUNTIME_SECONDS=900
JOB_REAPER_INTERVAL_SECONDS=60
JOB_REAPER_ENABLED=true

VOICEVOX_BASE_URL=http://voicevox:50021
VOICEVOX_TIMEOUT_SECONDS=30

PIPER_BASE_URL=
PIPER_TIMEOUT_SECONDS=60
PIPER_VOICE_IDS=vi_VN-vais1000-medium,en_US-lessac-medium,en_GB-alan-medium
PIPER_DOWNLOAD_ON_START=true

KOKORO_BASE_URL=
KOKORO_TIMEOUT_SECONDS=30

VIENEU_TTS_BASE_URL=
VIENEU_TTS_TIMEOUT_SECONDS=240

OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts

ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

GOOGLE_TTS_ACCESS_TOKEN=
GOOGLE_TTS_PROJECT_ID=

AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
